{
  "name": "@v/vivliostyle-pub",
  "version": "0.0.0",
  "author": "Vivliostyle Pub",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "check": "biome check .",
    "dev": "turbo dev",
    "fix": "biome check --write --unsafe .",
    "prepare": "husky",
    "test": "turbo test",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "pnpm": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "lint-staged": {
    "*": [
      "biome format --write --files-ignore-unknown=true --no-errors-on-unmatched"
    ]
  },
  "packageManager": "pnpm@11.1.2"
}
