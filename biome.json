{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              ":URL:",
              ":PACKAGE_WITH_PROTOCOL:",
              [":PACKAGE:", "!@v/**"],
              ":BLANK_LINE:",
              "**"
            ]
          }
        }
      }
    }
  },
  "css": {
    "formatter": {
      "enabled": true
    },
    "linter": {
      "enabled": true
    },
    "parser": {
      "cssModules": true,
      "tailwindDirectives": true
    }
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**",
      "!**/.wt/**",
      "!**/packages/cli-bundle/src/stubs/rollup/**/*",
      "!**/vivliostyle-pub/**/*",
      "!**/routeTree.gen.ts",
      "!**/packages/api-client/src/schema.d.ts",
      "!**/packages/api-spec/src/openapi.json",
      "!**/templates/**/*",
      "!!**/secrets"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "a11y": {
        "noLabelWithoutControl": {
          "level": "error",
          "options": {
            "inputComponents": [
              "Input",
              "Checkbox",
              "Switch",
              "Radio",
              "Select"
            ]
          }
        }
      },
      "correctness": {
        "noUnknownFunction": {
          "level": "off"
        }
      },
      "recommended": true
    }
  },
  "vcs": {
    "clientKind": "git",
    "enabled": true,
    "useIgnoreFile": true
  }
}
