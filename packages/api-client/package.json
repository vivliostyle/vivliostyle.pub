{
  "name": "@v/api-client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "build": "openapi-typescript ../api-spec/src/openapi.yaml --output src/schema.d.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@v/api-spec": "workspace:*",
    "@v/config": "workspace:*",
    "openapi-fetch": "catalog:",
    "openapi-typescript": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
