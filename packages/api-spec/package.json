{
  "name": "@v/api-spec",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./openapi.yaml": "./src/openapi.yaml"
  },
  "scripts": {
    "build": "node --import tsx scripts/generate.ts",
    "dev": "node --import tsx scripts/generate.ts --watch",
    "generate": "node --import tsx scripts/generate.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "yaml": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@v/api-server-reference": "workspace:*",
    "@v/config": "workspace:*",
    "tsx": "catalog:",
    "vitest": "catalog:"
  }
}
