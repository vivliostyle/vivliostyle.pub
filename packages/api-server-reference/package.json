    "@types/json-schema": "catalog:",
    "@types/node": "catalog:",
    "@v/config": "workspace:*",
    "@valibot/to-json-schema": "catalog:",
    "hono": "catalog:",
    "hono-openapi": "catalog:",
    "lib0": "catalog:",
    "openapi-types": "catalog:",
    "tsx": "catalog:",
    "valibot": "catalog:",
    "vitest": "catalog:",
    "y-protocols": "catalog:",
    "yjs": "catalog:"
  }
