{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalPassThroughEnv": ["TMPDIR"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "dist/**"]
    },
    "build:viewer-resource": {
      "inputs": [],
      "outputs": ["dist/viewer/**"]
    },
    "@v/cli-bundle#build": {
      "dependsOn": ["^build", "@v/cli-bundle#build:viewer-resource"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "@v/viola#build": {
      "dependsOn": ["^build"],
      "env": ["VITE_APP_*"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "@v/api-spec#build": {
      "dependsOn": ["^build"],
      "outputs": ["src/openapi.json"]
    },
    "@v/api-client#build": {
      "dependsOn": ["^build"],
      "outputs": ["src/schema.d.ts"]
    },
    "dev": {
      "dependsOn": ["@v/cli-bundle#build"],
      "cache": false,
      "persistent": true
    },
    "test": {
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["coverage/**"]
    },
    "@v/cli-bundle#test": {
      "dependsOn": ["@v/cli-bundle#build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": []
    }
  }
}
